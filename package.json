{
  "name": "loomscope",
  "private": true,
  "version": "1.0.0-rc.1",
  "type": "module",
  "description": "Visual viewer for Claude Code session transcripts (.jsonl) — DAG canvas of turns, tool calls, and sub-agents.",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "LOOMSCOPE_ALLOWED_ORIGIN=http://localhost:5174,http://localhost:5175 tsx watch src/server/cli.ts",
    "build": "tsc --noEmit && vite build",
    "build:server": "tsc --noEmit",
    "preview": "vite preview",
    "start": "tsx src/server/cli.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.133",
    "@dagrejs/dagre": "^1.1.4",
    "@hono/node-server": "^2.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@xyflow/react": "^12.3.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.16",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.47",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
