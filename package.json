{
  "name": "loomscope",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Visual viewer for Claude Code session transcripts (.jsonl) — DAG canvas of turns, tool calls, and sub-agents.",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/cli.ts",
    "build": "tsc --noEmit && vite build",
    "build:server": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@hono/node-server": "^2.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@xyflow/react": "^12.3.0",
    "commander": "^14.0.3",
    "hono": "^4.12.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "happy-dom": "^15.7.4",
    "postcss": "^8.4.47",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
